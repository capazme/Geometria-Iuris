# CLS Pipeline Environment Variables
# ====================================
# Copy this file to .env and fill in the values

# HuggingFace Token (optional - for private models or higher rate limits)
HF_TOKEN=

# Device override (optional): mps, cuda, cpu
# If not set, will auto-detect
# DEVICE=

# Model cache directory override (optional)
# TRANSFORMERS_CACHE=./models
